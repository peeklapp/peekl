{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/v1/certificates/retrieve": {
            "post": {
                "description": "retrieve a node signed certificate",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "certificates"
                ],
                "summary": "Retrieve a certificate once it has been signed",
                "parameters": [
                    {
                        "description": "Name of the node, along the CSR",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/requests.RetrieveSignedCertificate"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/responses.RetrieveSignedCertificate"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/responses.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/responses.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/certificates/root": {
            "get": {
                "description": "get root ca from server",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "certificates"
                ],
                "summary": "Used to get the root CA from the server",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/responses.GetRootCA"
                        }
                    }
                }
            }
        },
        "/v1/certificates/submit": {
            "post": {
                "description": "submit an unsigned certificate",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "certificates"
                ],
                "summary": "Used to submit a certificate",
                "parameters": [
                    {
                        "description": "Name of the node, along the CSR",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/requests.SubmitCertificateRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/responses.MessageResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/responses.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "requests.RetrieveSignedCertificate": {
            "type": "object",
            "required": [
                "csr",
                "node_name"
            ],
            "properties": {
                "csr": {
                    "type": "string"
                },
                "node_name": {
                    "type": "string"
                }
            }
        },
        "requests.SubmitCertificateRequest": {
            "type": "object",
            "required": [
                "csr",
                "node_name"
            ],
            "properties": {
                "csr": {
                    "type": "string"
                },
                "node_name": {
                    "type": "string"
                }
            }
        },
        "responses.ErrorResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                }
            }
        },
        "responses.GetRootCA": {
            "type": "object",
            "properties": {
                "certificate": {
                    "type": "string"
                }
            }
        },
        "responses.MessageResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "string"
                }
            }
        },
        "responses.RetrieveSignedCertificate": {
            "type": "object",
            "properties": {
                "certificate": {
                    "type": "string"
                }
            }
        }
    }
}